@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using Microsoft.AspNetCore.Components.Web
@using Web.Client
@inject NavigationManager NavigationManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <!-- Theme CSS variables - must load first -->
    <link href="styles/themes/default.css" rel="stylesheet" />
    <!-- BlazorBlueprint component styles -->
    <link href="_content/BlazorBlueprint.Components/blazorblueprint.css" rel="stylesheet" />
    <!-- App styles (Tailwind utilities for template pages) -->
    <link href="css/app.css" rel="stylesheet" />
    <HeadOutlet />
</head>
<body class="font-sans antialiased">
    <ErrorBoundary>
        <ChildContent>
            <Routes @rendermode="InteractiveAuto" />
        </ChildContent>
        <ErrorContent Context="err">
            <div class="p-4 bg-destructive text-destructive-foreground">
                <h2>アプリケーションエラー</h2>
                <pre>@err.ToString()</pre>
                <button class="mt-2 px-3 py-1 bg-primary text-white" @onclick="() => NavigationManager.NavigateTo(NavigationManager.Uri, true)">Reload</button>
            </div>
        </ErrorContent>
    </ErrorBoundary>

    <div id="blazor-error-ui" class="hidden fixed bottom-0 left-0 right-0 z-50 p-4 bg-destructive text-destructive-foreground">
        An error has occurred. This application may no longer respond until reloaded.
        <a href="" class="underline">Reload</a>
    </div>

    <script src="_framework/blazor.web.js"></script>
    <script>
        window.toggleDarkMode = () => document.documentElement.classList.toggle('dark');
        window.isDarkModeEnabled = () => document.documentElement.classList.contains('dark');

        function sendClientLog(payload) {
            try {
                fetch('/api/logs', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
            } catch (e) { console.error('Failed to send client log', e); }
        }

        window.addEventListener('error', function (evt) {
            try {
                const payload = {
                    message: evt.message,
                    filename: evt.filename,
                    lineno: evt.lineno,
                    colno: evt.colno,
                    stack: evt.error && evt.error.stack ? evt.error.stack : null,
                    time: new Date().toISOString(),
                    type: 'error'
                };
                sendClientLog(payload);
                const overlay = document.getElementById('blazor-error-ui');
                if (overlay) overlay.style.display = 'none';
                let banner = document.getElementById('custom-error-banner');
                if (!banner) {
                    banner = document.createElement('div');
                    banner.id = 'custom-error-banner';
                    banner.style = 'position:fixed;bottom:0;left:0;right:0;background:#b91c1c;color:#fff;padding:8px;z-index:9999;text-align:center;';
                    banner.innerText = 'アプリケーションエラーが発生しました。ページを再読み込みしてください。';
                    document.body.appendChild(banner);
                }
            } catch (e) { console.error(e); }
        });

        window.addEventListener('unhandledrejection', function (evt) {
            try {
                const reason = evt.reason;
                const payload = {
                    message: reason && reason.message ? reason.message : String(reason),
                    stack: reason && reason.stack ? reason.stack : null,
                    time: new Date().toISOString(),
                    type: 'unhandledrejection'
                };
                sendClientLog(payload);
                const overlay = document.getElementById('blazor-error-ui');
                if (overlay) overlay.style.display = 'none';
            } catch (e) { console.error(e); }
        });
    </script>
</body>
</html>
