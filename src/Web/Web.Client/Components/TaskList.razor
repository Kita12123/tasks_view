@using Web.Client.Api
@using Microsoft.AspNetCore.Components

<div class="task-list-wrapper">
    <table class="bp-table">
        <thead>
            <tr><th></th><th>タイトル</th><th>内容</th><th>期日</th><th>操作</th></tr>
        </thead>
        <tbody>
            @if (Items != null)
            {
                foreach (var t in Items)
                {
                    <TaskRow Item="t" OnToggle="OnToggle" OnEdit="OnEdit" OnDelete="OnDelete" OnSelect="OnSelect" />
                }
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public IEnumerable<Web.Client.Api.Task>? Items { get; set; }
    [Parameter] public EventCallback<Web.Client.Api.Task> OnToggle { get; set; }
    [Parameter] public EventCallback<System.Guid> OnEdit { get; set; }
    [Parameter] public EventCallback<System.Guid> OnDelete { get; set; }
    [Parameter] public EventCallback<Web.Client.Api.Task> OnSelect { get; set; }
}