@using Web.Client.Api
@using Microsoft.AspNetCore.Components

@if (Item == null)
{
    <div class="task-detail-empty">タスクを選択してください</div>
}
else
{
    <BbCard>
        <div class="p-4">
            <h2 class="text-xl font-semibold">@Item.Title</h2>
            <div class="mt-2 task-content">@((MarkupString)Item.Content)</div>
            <div class="mt-3 text-sm text-muted">期日: @(Item.DueDate.HasValue ? Item.DueDate.Value.ToString("yyyy-MM-dd") : "なし")</div>
            <div class="mt-3 text-sm text-muted">タグ: @(Item.Tags != null ? string.Join(", ", Item.Tags) : "-")</div>
            <div class="mt-4 flex gap-2">
                <BbButton Variant="ButtonVariant.Secondary" Size="ButtonSize.Small" @onclick="() => OnEdit.InvokeAsync(Item.Id)">編集</BbButton>
                <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small" @onclick="() => OnToggleComplete.InvokeAsync(Item)">@((Item.Completed) ? "未完了" : "完了")</BbButton>
                <BbButton Variant="ButtonVariant.Destructive" Size="ButtonSize.Small" @onclick="() => OnDelete.InvokeAsync(Item.Id)">削除</BbButton>
            </div>
        </div>
    </BbCard>
}

@code {
    [Parameter] public Web.Client.Api.Task? Item { get; set; }
    [Parameter] public EventCallback<System.Guid> OnEdit { get; set; }
    [Parameter] public EventCallback<Web.Client.Api.Task> OnToggleComplete { get; set; }
    [Parameter] public EventCallback<System.Guid> OnDelete { get; set; }
}