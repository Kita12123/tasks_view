@using Web.Client.Api
@using Microsoft.AspNetCore.Components

@if (Visible)
{
    <div class="modal-backdrop" @onclick="Cancel" style="position:fixed;inset:0;background:rgba(0,0,0,0.35);display:flex;align-items:center;justify-content:center;">
        <BbCard Class="p-4" @onclick:stopPropagation>
            <h3>@(IsNew ? "新規タスク作成" : "タスク編集")</h3>
            <div class="mt-3">
                <label class="block text-sm mb-1">タイトル</label>
                <BbInput @bind-Value="model.Title" />
            </div>
            <div class="mt-3">
                <label class="block text-sm mb-1">内容</label>
                <textarea class="bb-textarea w-full" @bind="model.Content"></textarea>
            </div>
            <div class="mt-3">
                <label class="block text-sm mb-1">期日</label>
                <input type="date" value="@dueDateString" @onchange="OnDueDateChanged" class="bb-input" />
            </div>
            <div class="modal-actions mt-4 flex justify-end gap-2">
                            <BbButton @onclick="Save">保存</BbButton>
                <BbButton Variant="ButtonVariant.Outline" @onclick="Cancel">キャンセル</BbButton>
            </div>
        </BbCard>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback<Web.Client.Api.Task> OnSave { get; set; }
    [Parameter] public Web.Client.Api.Task? Model { get; set; }

    private Web.Client.Api.Task model = new Web.Client.Api.Task();
    private string? dueDateString;
    private bool IsNew => Model == null;

    protected override void OnParametersSet()
    {
        if (Model != null)
        {
            model = new Web.Client.Api.Task
            {
                Id = Model.Id,
                Title = Model.Title,
                Content = Model.Content,
                DueDate = Model.DueDate,
                Completed = Model.Completed,
                Tags = Model.Tags
            };
            dueDateString = model.DueDate?.ToString("yyyy-MM-dd");
        }
        else
        {
            model = new Web.Client.Api.Task();
            dueDateString = null;
        }
    }

    private async System.Threading.Tasks.Task Save()
    {
        if (!string.IsNullOrWhiteSpace(dueDateString))
        {
            if (System.DateTimeOffset.TryParse(dueDateString, out var dto)) model.DueDate = dto;
        }
        await OnSave.InvokeAsync(model);
    }

    private void OnDueDateChanged(ChangeEventArgs e)
    {
        dueDateString = e?.Value?.ToString();
    }

    private async System.Threading.Tasks.Task Cancel() => await OnCancel.InvokeAsync(null);
}