@page "/tasks"
@inject Web.Client.Api.IClient ApiClient
@inject NavigationManager NavigationManager

<h1>Tasks</h1>
<BbButton @onclick="CreateTask">＋ タスクを追加</BbButton>

@if (loading)
{
    <p>Loading...</p>
}
else if (tasks == null || tasks.Items == null || tasks.Items.Count == 0)
{
    <p>No tasks</p>
}
else
{
    <div style="display:flex;gap:16px;align-items:flex-start;">
        <div style="flex:1;">
            <TaskFilters OnSearch="OnSearch" />
            <TaskList Items="tasks.Items" OnToggle="ToggleComplete" OnEdit="Edit" OnDelete="Delete" OnSelect="SelectTask" />
            <div style="margin-top:8px;">
                <BbButton Variant="ButtonVariant.Outline" @onclick="PrevPage">前へ</BbButton>
                <BbButton @onclick="NextPage">次へ</BbButton>
            </div>
        </div>
        <div style="width:360px;">
            <TaskDetail Item="selectedTask" OnEdit="Edit" OnToggleComplete="ToggleComplete" OnDelete="Delete" />
        </div>
    </div>
}

@code {
    private Web.Client.Api.TaskList? tasks;
    private bool loading = true;
    private int page = 1;
    private int perPage = 25;
    private Web.Client.Api.Task? selectedTask;
    private string? searchKeyword;

    protected override async System.Threading.Tasks.Task OnInitializedAsync()
    {
        await Load();
    }

    private async System.Threading.Tasks.Task Load()
    {
        loading = true;
        try
        {
            tasks = await ApiClient.ListTasksAsync(searchKeyword, null, null, "dueDate", page, perPage);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Load error: {ex}");
        }
        finally
        {
            loading = false;
        }
    }

    private void CreateTask()
    {
        NavigationManager.NavigateTo("/tasks/new");
    }

    private void Edit(System.Guid id)
    {
        NavigationManager.NavigateTo($"/tasks/{id}");
    }

    private async System.Threading.Tasks.Task Delete(System.Guid id)
    {
        try
        {
            await ApiClient.DeleteTaskAsync(id.ToString());
            await Load();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Delete error: {ex}");
        }
    }

    private async System.Threading.Tasks.Task ToggleComplete(Web.Client.Api.Task t)
    {
        try
        {
            if (t.Completed)
            {
                await ApiClient.UncompleteTaskAsync(t.Id.ToString());
            }
            else
            {
                await ApiClient.CompleteTaskAsync(t.Id.ToString());
            }
            await Load();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"ToggleComplete error: {ex}");
        }
    }

    private void SelectTask(Web.Client.Api.Task t)
    {
        selectedTask = t;
    }

    private async System.Threading.Tasks.Task OnSearch(string kw)
    {
        searchKeyword = kw;
        page = 1;
        await Load();
    }

    private async System.Threading.Tasks.Task PrevPage()
    {
        if (page > 1) { page--; await Load(); }
    }

    private async System.Threading.Tasks.Task NextPage()
    {
        page++; await Load();
    }
}
