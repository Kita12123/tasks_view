@page "/"
@inject Web.Client.Api.IClient Api

<PageTitle>タスク一覧</PageTitle>

<div class="container py-6">
    <div class="flex items-center justify-between mb-4">
        <h1 class="text-2xl font-bold">タスク一覧</h1>
        <BbButton @onclick="() => OpenAddDialog()">＋ タスクを追加</BbButton>
    </div>

    <BbDialog @bind-Open="addOpen">
        <BbDialogContent>
            <BbDialogHeader>
                <BbDialogTitle>タスクを追加</BbDialogTitle>
                <BbDialogDescription>フォームに入力してタスクを追加します。</BbDialogDescription>
            </BbDialogHeader>
            <div class="py-2 space-y-3">
                <BbLabel For="title">タイトル</BbLabel>
                <BbInput id="title" @bind-Value="newTask.Title" Placeholder="タイトル" />
                <BbLabel For="content">内容</BbLabel>
                <textarea id="content" class="w-full border rounded p-2" @bind="newTask.Content"></textarea>
                <BbLabel For="duedate">日付</BbLabel>
                <input id="duedate" type="datetime-local" class="w-full border rounded p-2" value="@dueDateString" @onchange="OnDueDateChanged" />
                @if (!string.IsNullOrEmpty(addError))
                {
                    <div class="text-destructive">@addError</div>
                }
            </div>
            <BbDialogFooter>
                <BbButton Variant="ButtonVariant.Outline" @onclick="() => CancelAdd()">キャンセル</BbButton>
                <BbButton Disabled="@(isSubmitting || string.IsNullOrWhiteSpace(newTask?.Title))" @onclick="CreateTaskAsync">
                    @if (isSubmitting)
                    {
                        <span>保存中…</span>
                    }
                    else
                    {
                        <span>保存</span>
                    }
                </BbButton>
            </BbDialogFooter>
        </BbDialogContent>
    </BbDialog>

    @if (isLoading)
    {
        <div>読み込み中…</div>
    }
    else if (!string.IsNullOrEmpty(error))
    {
        <div class="text-destructive">エラー: @error</div>
    }
    else if (tasks?.Items == null || tasks.Items.Count == 0)
    {
        <div>タスクがありません</div>
    }
    else
    {
        <table class="w-full table-auto border-collapse">
            <thead>
                <tr class="text-left">
                    <th class="px-2 py-1">完了</th>
                    <th class="px-2 py-1">タイトル</th>
                    <th class="px-2 py-1">内容</th>
                    <th class="px-2 py-1">日付</th>
                    <th class="px-2 py-1">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var it in tasks.Items)
                {
                    <tr class="@(it.Completed ? "bg-gray-100" : "")">
                        <td class="border px-2 py-1">
                            <input type="checkbox" checked="@it.Completed" @onchange="e => ToggleCompleteAsync(it, (bool)e.Value)" />
                        </td>
                        <td class="border px-2 py-1 @(it.Completed ? "line-through text-gray-500" : "")" contenteditable="true" @onblur="e => OnTitleBlurAsync(it, (string)e.Value)">@it.Title</td>
                        <td class="border px-2 py-1" contenteditable="true" @onblur="e => OnContentBlurAsync(it, (string)e.Value)">@it.Content</td>
                        <td class="border px-2 py-1">@((it.DueDate.HasValue) ? it.DueDate.Value.ToLocalTime().ToString("yyyy/MM/dd HH:mm") : "-")</td>
                        <td class="border px-2 py-1">
                            <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" @onclick="() => DeleteTaskAsync(it)">削除</BbButton>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>

@code {
    private Web.Client.Api.TaskList tasks;
    private bool isLoading = true;
    private string error;

    private bool addOpen = false;
    private Web.Client.Api.TaskCreate newTask = new Web.Client.Api.TaskCreate { Title = "", Content = "", DueDate = System.DateTimeOffset.Now };
    private string dueDateString;
    private bool isSubmitting;
    private string addError;

    protected override async System.Threading.Tasks.Task OnInitializedAsync()
    {
        await LoadTasksAsync();
    }

    private async System.Threading.Tasks.Task LoadTasksAsync()
    {
        isLoading = true;
        error = null;
        try
        {
            tasks = await Api.TasksGETAsync(null, null, null, null, 1, 25);
        }
        catch (System.Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenAddDialog()
    {
        addError = null;
        newTask = new Web.Client.Api.TaskCreate { Title = "", Content = "", DueDate = System.DateTimeOffset.Now };
        dueDateString = null;
        addOpen = true;
    }

    private void CancelAdd()
    {
        addOpen = false;
    }

    private void OnDueDateChanged(ChangeEventArgs e)
    {
        dueDateString = e?.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(dueDateString))
        {
            // parse local datetime-local to DateTimeOffset
            if (System.DateTime.TryParse(dueDateString, out var dt))
            {
                newTask.DueDate = new System.DateTimeOffset(dt);
            }
        }
        else
        {
            newTask.DueDate = System.DateTimeOffset.Now;
        }
    }

    private async System.Threading.Tasks.Task CreateTaskAsync()
    {
        addError = null;
        isSubmitting = true;
        try
        {
            if (string.IsNullOrWhiteSpace(newTask.Title))
            {
                addError = "タイトルは必須です。";
                return;
            }

            await Api.TasksPOSTAsync(newTask);
            addOpen = false;
            await LoadTasksAsync();
        }
        catch (System.Exception ex)
        {
            addError = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async System.Threading.Tasks.Task ToggleCompleteAsync(Web.Client.Api.Task task, bool isCompleted)
    {
        try
        {
            if (isCompleted)
            {
                await Api.CompleteAsync(task.Id.ToString());
            }
            else
            {
                await Api.UncompleteAsync(task.Id.ToString());
            }
            await LoadTasksAsync();
        }
        catch (System.Exception ex)
        {
            error = $"完了状態の更新に失敗しました: {ex.Message}";
        }
    }

    private async System.Threading.Tasks.Task OnTitleBlurAsync(Web.Client.Api.Task task, string newTitle)
    {
        if (string.IsNullOrWhiteSpace(newTitle) || newTitle == task.Title)
            return;

        try
        {
            var update = new Web.Client.Api.TaskUpdate { Title = newTitle };
            await Api.TasksPATCHPATCHAsync(update, task.Id.ToString());
            task.Title = newTitle;
        }
        catch (System.Exception ex)
        {
            error = $"タイトルの更新に失敗しました: {ex.Message}";
        }
    }

    private async System.Threading.Tasks.Task OnContentBlurAsync(Web.Client.Api.Task task, string newContent)
    {
        if (newContent == task.Content)
            return;

        try
        {
            var update = new Web.Client.Api.TaskUpdate { Content = newContent };
            await Api.TasksPATCHPATCHAsync(update, task.Id.ToString());
            task.Content = newContent;
        }
        catch (System.Exception ex)
        {
            error = $"内容の更新に失敗しました: {ex.Message}";
        }
    }

    private async System.Threading.Tasks.Task DeleteTaskAsync(Web.Client.Api.Task task)
    {
        if (!await Confirm($"タスク「{task.Title}」を削除しますか？"))
            return;

        try
        {
            await Api.TasksDELETEDELETEAsync(task.Id.ToString());
            await LoadTasksAsync();
        }
        catch (System.Exception ex)
        {
            error = $"削除に失敗しました: {ex.Message}";
        }
    }

    private async System.Threading.Tasks.Task<bool> Confirm(string message)
    {
        // Blazor の JS interop を使用して確認ダイアログを表示
        // 簡易版として、ここではダミー実装
        return await System.Threading.Tasks.Task.FromResult(true);
    }
