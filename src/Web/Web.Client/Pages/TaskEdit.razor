@page "/tasks/new"
@page "/tasks/{Id:guid}"

@inject Web.Client.Api.IClient ApiClient
@inject NavigationManager NavigationManager

<div class="max-w-2xl">
    <h3 class="text-lg font-semibold">@(IsNew ? "タスクを作成" : "タスクを編集")</h3>

    <div class="mt-4">        <label class="block text-sm mb-1">タイトル</label>        <BbInput id="title" @bind-Value="model.Title" />    </div>    <div class="mt-4">        <label class="block text-sm mb-1">内容</label>        <textarea id="content" class="bb-textarea w-full" @bind="model.Content"></textarea>    </div>    <div class="mt-4">        <label class="block text-sm mb-1">期日</label>        <input id="duedate" class="bb-input" type="text" @bind="dueDateString" />    </div>    <div class="mt-4">        @if (!string.IsNullOrEmpty(saveError))        {            <div class="text-destructive">@saveError</div>        }        <div class="flex gap-2 mt-2">            <BbButton id="save" @onclick="Save">保存</BbButton>            <BbButton id="cancel" Variant="ButtonVariant.Outline" @onclick="Cancel">キャンセル</BbButton>        </div>    </div></div>@code {    [Parameter]    public System.Guid? Id { get; set; }    private Web.Client.Api.TaskCreate model = new Web.Client.Api.TaskCreate();    private string dueDateString = "";    private bool IsNew => !Id.HasValue;    private string? saveError;    protected override async System.Threading.Tasks.Task OnInitializedAsync()    {        try        {            if (IsNew)            {                model.Tags = new System.Collections.Generic.List<string>();                model.DueDate = System.DateTimeOffset.Now;                return;            }            var t = await ApiClient.GetTaskAsync(Id.ToString());            model.Title = t.Title;            model.Content = t.Content;            if (t.DueDate.HasValue)            {                dueDateString = t.DueDate.Value.ToLocalTime().ToString("yyyy-MM-ddTHH:mm");                model.DueDate = t.DueDate.Value;            }            model.Tags = t.Tags ?? new System.Collections.Generic.List<string>();        }        catch (Exception ex)        {            saveError = ex.Message;            Console.Error.WriteLine($"OnInitialized error: {ex}");        }    }    private async System.Threading.Tasks.Task Save()    {        saveError = null;        try        {            if (!string.IsNullOrEmpty(dueDateString))            {                if (System.DateTimeOffset.TryParse(dueDateString, out var dto))                {                    model.DueDate = dto;                }                else                {                    model.DueDate = System.DateTimeOffset.Now;                }            }            if (IsNew)            {                await ApiClient.CreateTaskAsync(model);            }            else            {                await ApiClient.ReplaceTaskAsync(model, Id.ToString());            }            NavigationManager.NavigateTo("/tasks");        }        catch (Exception ex)        {            saveError = ex.Message;            Console.Error.WriteLine($"Task save error: {ex}");        }    }    private void Cancel()    {        NavigationManager.NavigateTo("/tasks");    }}
