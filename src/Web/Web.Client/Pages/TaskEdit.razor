@page "/tasks/new"
@page "/tasks/{Id:guid}"

@inject Web.Client.Api.IClient ApiClient
@inject NavigationManager NavigationManager

<h3>@(IsNew ? "Create Task" : "Edit Task")</h3>

<div>
    <label>Title</label>
    <input @bind="model.Title" />
</div>
<div>
    <label>Content</label>
    <textarea @bind="model.Content"></textarea>
</div>
<div>
    <label>Due</label>
    <input type="text" @bind="dueDateString" />
</div>
<div>
    <button @onclick="Save">Save</button>
    <button @onclick="Cancel">Cancel</button>
</div>

@code {
    [Parameter]
    public System.Guid? Id { get; set; }

    private Web.Client.Api.TaskCreate model = new Web.Client.Api.TaskCreate();
    private string dueDateString = "";
    private bool IsNew => !Id.HasValue;

    protected override async System.Threading.Tasks.Task OnInitializedAsync()
    {
        if (IsNew)
        {
            model.Tags = new System.Collections.Generic.List<string>();
            model.DueDate = System.DateTimeOffset.Now;
            return;
        }

        var t = await ApiClient.TasksGETGET22Async(Id.ToString());
        model.Title = t.Title;
        model.Content = t.Content;
        if (t.DueDate.HasValue)
        {
            dueDateString = t.DueDate.Value.ToLocalTime().ToString("yyyy-MM-ddTHH:mm");
            model.DueDate = t.DueDate.Value;
        }
        model.Tags = t.Tags ?? new System.Collections.Generic.List<string>();
    }

    private async System.Threading.Tasks.Task Save()
    {
        if (!string.IsNullOrEmpty(dueDateString))
        {
            if (System.DateTimeOffset.TryParse(dueDateString, out var dto))
            {
                model.DueDate = dto;
            }
            else
            {
                model.DueDate = System.DateTimeOffset.Now;
            }
        }

        if (IsNew)
        {
            await ApiClient.TasksPOSTPOSTAsync(model);
        }
        else
        {
            await ApiClient.TasksPUTPUTAsync(model, Id.ToString());
        }

        NavigationManager.NavigateTo("/tasks");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/tasks");
    }
}
