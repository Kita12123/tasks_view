@page "/tasks/new"
@page "/tasks/{Id:guid}"

@inject Web.Client.Api.IClient ApiClient
@inject NavigationManager NavigationManager

<h3>@(IsNew ? "Create Task" : "Edit Task")</h3>

<div>
    <label>Title</label>
    <BbInput id="title" @bind-Value="model.Title" />
</div>
<div>
    <label>Content</label>
    <textarea id="content" @bind="model.Content"></textarea>
</div>
<div>
    <label>Due</label>
    <input id="duedate" type="text" @bind="dueDateString" />
</div>
<div>
    @if (!string.IsNullOrEmpty(saveError))
    {
        <div class="text-destructive">@saveError</div>
    }
    <BbButton id="save" @onclick="Save">保存</BbButton>
    <BbButton id="cancel" Variant="ButtonVariant.Outline" @onclick="Cancel">キャンセル</BbButton>
</div>

@code {
    [Parameter]
    public System.Guid? Id { get; set; }

    private Web.Client.Api.TaskCreate model = new Web.Client.Api.TaskCreate();
    private string dueDateString = "";
    private bool IsNew => !Id.HasValue;
    private string? saveError;

    protected override async System.Threading.Tasks.Task OnInitializedAsync()
    {
        try
        {
            if (IsNew)
            {
                model.Tags = new System.Collections.Generic.List<string>();
                model.DueDate = System.DateTimeOffset.Now;
                return;
            }

            var t = await ApiClient.GetTaskAsync(Id.ToString());
            model.Title = t.Title;
            model.Content = t.Content;
            if (t.DueDate.HasValue)
            {
                dueDateString = t.DueDate.Value.ToLocalTime().ToString("yyyy-MM-ddTHH:mm");
                model.DueDate = t.DueDate.Value;
            }
            model.Tags = t.Tags ?? new System.Collections.Generic.List<string>();
        }
        catch (Exception ex)
        {
            saveError = ex.Message;
            Console.Error.WriteLine($"OnInitialized error: {ex}");
        }
    }

    private async System.Threading.Tasks.Task Save()
    {
        saveError = null;
        try
        {
            if (!string.IsNullOrEmpty(dueDateString))
            {
                if (System.DateTimeOffset.TryParse(dueDateString, out var dto))
                {
                    model.DueDate = dto;
                }
                else
                {
                    model.DueDate = System.DateTimeOffset.Now;
                }
            }

            if (IsNew)
            {
                await ApiClient.CreateTaskAsync(model);
            }
            else
            {
                await ApiClient.ReplaceTaskAsync(model, Id.ToString());
            }

            NavigationManager.NavigateTo("/tasks");
        }
        catch (Exception ex)
        {
            saveError = ex.Message;
            Console.Error.WriteLine($"Task save error: {ex}");
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/tasks");
    }
}
